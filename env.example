# =============================================================================
# Copy this file to `.env` before running the app:  cp env.example .env
# It is named without the leading dot so the tooling can create it; git will
# still ignore any file named `.env` (see .gitignore).
# =============================================================================

# =============================================================================
# PostgreSQL — must match docker-compose.yml (defaults are dev-only).
# =============================================================================
POSTGRES_USER=arxiv_rag
POSTGRES_PASSWORD=arxiv_rag_dev
POSTGRES_DB=arxiv_rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =============================================================================
# Local ML models (sentence-transformers). Free, CPU-friendly.
# Defaults chosen for a RAM-limited VPS — total ML footprint ~400 MB.
#   bge-small-en-v1.5:      ~130 MB weights, 384-d vectors, English-only
#   ms-marco-MiniLM-L-6-v2: ~90 MB weights, English cross-encoder rerank
# EMBEDDING_DIMENSION must match the model output AND the VECTOR(N) column
# in sql/schema.sql — changing dimension requires re-indexing the corpus.
# =============================================================================
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
MODEL_DEVICE=cpu

# =============================================================================
# arXiv API — https://info.arxiv.org/help/api/user-manual.html
# arXiv asks for at most 1 request every 3 seconds. Respect it.
# =============================================================================
ARXIV_API_BASE=https://export.arxiv.org/api/query
ARXIV_REQUEST_INTERVAL_SECONDS=3
ARXIV_MAX_RESULTS_PER_PAGE=100
BACKFILL_MAX_PAPERS=500
# arXiv requires an identifiable User-Agent — anonymous / default-python UAs
# get 429'd on first contact. Add a mailto: for stronger identification, e.g.
# "arxiv-rag/1.0 (+https://your-domain.com; mailto:you@example.com)".
ARXIV_USER_AGENT=arxiv-rag/1.0 (+https://github.com/LeanAlvarez/rag_science_questions)

# =============================================================================
# Chunking (token counts, not characters).
# =============================================================================
CHUNK_SIZE_TOKENS=400
CHUNK_OVERLAP_TOKENS=50

# =============================================================================
# Retrieval + rerank pipeline knobs.
#   1) vector search returns TOP_K_VECTOR candidates
#   2) keyword search returns TOP_K_KEYWORD candidates
#   3) RRF fuses both lists into TOP_K_AFTER_RRF
#   4) cross-encoder rerank picks the final RERANK_TOP_K
# =============================================================================
RETRIEVAL_TOP_K_VECTOR=30
RETRIEVAL_TOP_K_KEYWORD=30
RETRIEVAL_TOP_K_AFTER_RRF=20
RERANK_TOP_K=5
RRF_K=60

# =============================================================================
# OpenRouter (generation). Get a key at https://openrouter.ai/keys
# OPENROUTER_MODELS is an ORDERED comma-separated fallback list. Free-tier
# models rotate constantly — if a model 404s or rate-limits, the next one is
# tried. Check https://openrouter.ai/models?max_price=0 for the current list
# and paste your preferred IDs (they must end in ":free" for the free tier).
# Free tier limits: ~20 req/min and 50 req/day (subject to change).
# =============================================================================
OPENROUTER_API_KEY=
OPENROUTER_MODELS=
OPENROUTER_REFERER=https://github.com/your-user/arxiv-rag
OPENROUTER_TITLE=arxiv-rag
OPENROUTER_MAX_TOKENS=1024
OPENROUTER_TEMPERATURE=0.2

# =============================================================================
# Telegram bot (Phase 5). Talk to @BotFather to get a token.
# =============================================================================
TELEGRAM_BOT_TOKEN=

# =============================================================================
# Web API (Phase 4).
# =============================================================================
WEB_HOST=127.0.0.1
WEB_PORT=8000

# =============================================================================
# Web CORS — comma-separated origins for the FastAPI CORS middleware.
# In dev the Vite frontend runs on http://localhost:5173. In prod (same-origin)
# you can leave this empty and skip the middleware entirely.
# =============================================================================
WEB_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
